# OpenAI API key for AI chat (optional - chat works offline without it)
VITE_OPENAI_API_KEY=sk-your-openai-api-key-here

# Email configuration (optional - uses Ethereal test email if not set)
# For Gmail: enable 2FA and generate an App Password at https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
